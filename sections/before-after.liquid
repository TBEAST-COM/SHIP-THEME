{%- comment -%} Before / After comparison slider — TBEAST identity {%- endcomment -%}
{%- assign s = section.settings -%}
{%- style -%}
  #fxba-{{ section.id }}{ padding-block:{{ s.pad | default: 72 }}px; position:relative; z-index:1; }
  #fxba-{{ section.id }} .fxba-head{ max-width:1100px; margin:0 auto 32px; text-align:center; }
  #fxba-{{ section.id }} .fxba-title{ font-family:var(--display); font-weight:700; font-size:clamp(30px,4.5vw,52px); color:var(--text); line-height:1.05; letter-spacing:-0.01em; margin:10px 0 0; }
  #fxba-{{ section.id }} .fxba-wrap{ position:relative; max-width:{{ s.max_w | default: 1000 }}px; margin:0 auto; aspect-ratio:{{ s.ratio | default: '16/9' }}; overflow:hidden; border-radius:var(--radius); border:1px solid var(--line); user-select:none; touch-action:none; cursor:ew-resize; background:var(--card); }
  #fxba-{{ section.id }} .fxba-img{ position:absolute; inset:0; width:100%; height:100%; object-fit:cover; }
  #fxba-{{ section.id }} .fxba-after{ clip-path:inset(0 0 0 var(--pos,50%)); }
  [dir="rtl"] #fxba-{{ section.id }} .fxba-after{ clip-path:inset(0 var(--pos,50%) 0 0); }
  #fxba-{{ section.id }} .fxba-ph{ position:absolute; inset:0; display:flex; align-items:center; justify-content:center; font-family:var(--display); font-weight:700; font-size:38px; letter-spacing:3px; }
  #fxba-{{ section.id }} .fxba-line{ position:absolute; top:0; bottom:0; left:var(--pos,50%); width:2px; background:var(--accent-2); transform:translateX(-1px); z-index:3; box-shadow:0 0 18px oklch(0 0 0 / 0.5); }
  #fxba-{{ section.id }} .fxba-handle{ position:absolute; top:50%; left:var(--pos,50%); transform:translate(-50%,-50%); z-index:4; width:50px; height:50px; border-radius:50%; background:linear-gradient(135deg,var(--sale),var(--accent)); border:3px solid var(--bg); display:flex; align-items:center; justify-content:center; color:var(--bg); box-shadow:0 6px 20px oklch(0 0 0 / 0.45); }
  #fxba-{{ section.id }} .fxba-handle svg{ width:22px; height:22px; }
  #fxba-{{ section.id }} .fxba-label{ position:absolute; bottom:16px; z-index:3; font-family:var(--mono); font-size:11px; font-weight:600; letter-spacing:.12em; text-transform:uppercase; color:#fff; background:oklch(0.16 0.012 60 / 0.6); backdrop-filter:blur(6px); padding:7px 13px; border-radius:30px; border:1px solid oklch(1 0 0 / 0.18); }
  #fxba-{{ section.id }} .fxba-label.before{ inset-inline-start:16px; } #fxba-{{ section.id }} .fxba-label.after{ inset-inline-end:16px; }
{%- endstyle -%}

<section id="fxba-{{ section.id }}" class="wrap tb-reveal" {{ section.shopify_attributes }}>
  {%- if s.kicker != blank or s.title != blank -%}
  <div class="fxba-head">
    {%- if s.kicker != blank -%}<div class="tb-kicker">{{ s.kicker }}</div>{%- endif -%}
    {%- if s.title != blank -%}<h2 class="fxba-title">{{ s.title }}</h2>{%- endif -%}
  </div>
  {%- endif -%}
  <div class="fxba-wrap" data-ba style="--pos:{{ s.start | default: 50 }}%" tabindex="0" role="slider" aria-valuenow="{{ s.start | default: 50 }}" aria-valuemin="0" aria-valuemax="100" aria-label="Before after comparison">
    {%- if s.image_before != blank -%}
      <img class="fxba-img fxba-before" src="{{ s.image_before | image_url: width: 1600 }}" alt="Before" draggable="false">
    {%- else -%}<div class="fxba-img fxba-ph" style="background:var(--bg-2);color:var(--muted)">BEFORE</div>{%- endif -%}
    {%- if s.image_after != blank -%}
      <img class="fxba-img fxba-after" src="{{ s.image_after | image_url: width: 1600 }}" alt="After" draggable="false">
    {%- else -%}<div class="fxba-img fxba-after fxba-ph" style="background:oklch(0.24 0.05 45);color:var(--accent-2)">AFTER</div>{%- endif -%}
    <div class="fxba-line"></div>
    <div class="fxba-handle"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m9 7-5 5 5 5M15 7l5 5-5 5"/></svg></div>
    {%- if s.label_before != blank -%}<span class="fxba-label before">{{ s.label_before }}</span>{%- endif -%}
    {%- if s.label_after != blank -%}<span class="fxba-label after">{{ s.label_after }}</span>{%- endif -%}
  </div>
</section>

<script>
(function(){
  var root=document.getElementById('fxba-{{ section.id }}');
  if(!root) return;
  var wrap=root.querySelector('[data-ba]');
  var rtl=document.documentElement.getAttribute('dir')==='rtl';
  var dragging=false;
  function setPos(clientX){ var r=wrap.getBoundingClientRect(); var p=((clientX-r.left)/r.width)*100; if(rtl)p=100-p; p=Math.max(0,Math.min(100,p)); wrap.style.setProperty('--pos',p.toFixed(1)+'%'); wrap.setAttribute('aria-valuenow',Math.round(p)); }
  function down(e){ dragging=true; setPos(e.touches?e.touches[0].clientX:e.clientX); e.preventDefault(); }
  function move(e){ if(!dragging) return; setPos(e.touches?e.touches[0].clientX:e.clientX); }
  function up(){ dragging=false; }
  wrap.addEventListener('mousedown',down); window.addEventListener('mousemove',move); window.addEventListener('mouseup',up);
  wrap.addEventListener('touchstart',down,{passive:false}); window.addEventListener('touchmove',move,{passive:false}); window.addEventListener('touchend',up);
  wrap.addEventListener('keydown',function(e){ var cur=parseFloat(wrap.style.getPropertyValue('--pos'))||50; if(e.key==='ArrowLeft'){ cur-=4; } else if(e.key==='ArrowRight'){ cur+=4; } else return; cur=Math.max(0,Math.min(100,cur)); wrap.style.setProperty('--pos',cur+'%'); wrap.setAttribute('aria-valuenow',Math.round(cur)); e.preventDefault(); });
})();
</script>

{% schema %}
{
  "name": "Before / After",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "THE DIFFERENCE" },
    { "type": "text", "id": "title", "label": "Title", "default": "Before & after" },
    { "type": "image_picker", "id": "image_before", "label": "Before image" },
    { "type": "image_picker", "id": "image_after", "label": "After image" },
    { "type": "text", "id": "label_before", "label": "Before label", "default": "BEFORE" },
    { "type": "text", "id": "label_after", "label": "After label", "default": "AFTER" },
    { "type": "range", "id": "start", "label": "Start position (%)", "min": 0, "max": 100, "step": 5, "default": 50 },
    { "type": "select", "id": "ratio", "label": "Aspect ratio", "options": [
      { "value": "16/9", "label": "16:9" }, { "value": "4/3", "label": "4:3" }, { "value": "1/1", "label": "1:1" }, { "value": "3/2", "label": "3:2" }
    ], "default": "16/9" },
    { "type": "range", "id": "max_w", "label": "Max width (px)", "min": 500, "max": 1400, "step": 20, "default": 1000 },
    { "type": "range", "id": "pad", "label": "Padding (px)", "min": 40, "max": 200, "step": 10, "default": 72 }
  ],
  "presets": [{ "name": "Before / After" }]
}
{% endschema %}
