{%- comment -%} Countdown promo banner {%- endcomment -%}
<section class="wrap tb-reveal" style="padding-block:40px;">
  <div class="tb-count" style="--cd-bg:{{ section.settings.bg_color }};" data-countdown="{{ section.settings.end_date }}">
    <div class="tb-count__glow"></div>
    <div class="tb-count__text">
      {%- if section.settings.kicker != blank -%}<div class="tb-kicker" style="color:var(--accent-2);">{{ section.settings.kicker }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="tb-section-title" style="font-size:clamp(24px,3.4vw,36px);">{{ section.settings.heading }}</h2>{%- endif -%}
    </div>
    <div class="tb-count__right">
      <div class="tb-count__clock" data-clock>
        <div class="tb-count__unit"><b data-d>00</b><span>{{ 'general.countdown.days' | t }}</span></div>
        <div class="tb-count__unit"><b data-h>00</b><span>{{ 'general.countdown.hours' | t }}</span></div>
        <div class="tb-count__unit"><b data-m>00</b><span>{{ 'general.countdown.mins' | t }}</span></div>
        <div class="tb-count__unit"><b data-s>00</b><span>{{ 'general.countdown.secs' | t }}</span></div>
      </div>
      {%- if section.settings.button_text != blank -%}
        <a class="tb-btn tb-btn--light" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">{{ section.settings.button_text }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Countdown banner",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#3a2418" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "LIMITED TIME" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Flash sale — up to 40% off" },
    { "type": "text", "id": "end_date", "label": "End date (YYYY/MM/DD HH:MM)", "info": "e.g. 2026/12/31 23:59", "default": "2026/12/31 23:59" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Shop the sale" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [ { "name": "Countdown banner" } ]
}
{% endschema %}
