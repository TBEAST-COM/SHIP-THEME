<section class="wrap tb-reveal" style="padding-block:64px 8px;">
  <div class="tb-section-head">
    <div>
      {%- if section.settings.kicker != blank -%}<div class="tb-kicker">{{ section.settings.kicker }}</div>{%- endif -%}
      <h2 class="tb-section-title">{{ section.settings.heading }}</h2>
    </div>
  </div>
  <div class="tb-cat-grid">
    {%- for block in section.blocks -%}
      {%- assign col = block.settings.collection -%}
      {%- assign cimg = col.image | default: col.products.first.featured_image -%}
      <a class="tb-cat{% if cimg != blank %} tb-cat--img{% endif %}" href="{{ col.url | default: routes.all_products_collection_url }}" {{ block.shopify_attributes }}>
        {%- if cimg != blank -%}<img class="tb-cat__bg" src="{{ cimg | image_url: width: 700 }}" alt="{{ col.title | escape }}" loading="lazy">{%- endif -%}
        <span class="tb-cat__name">{{ block.settings.title | default: col.title }}</span>
        <span class="tb-cat__link">{{ 'collections.general.explore' | t }} <span class="mono">{% if request.locale.iso_code == 'ar' %}&larr;{% else %}&rarr;{% endif %}</span></span>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection list",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "BROWSE BY CATEGORY" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Explore the collections" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "title", "label": "Override title" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Collection list",
      "blocks": [
        { "type": "item" }, { "type": "item" }, { "type": "item" }, { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
