{%- comment -%} Testimonials / reviews {%- endcomment -%}
<section class="wrap tb-reveal" style="padding-block:64px;">
  <div class="tb-section-head" style="justify-content:center;text-align:center;flex-direction:column;align-items:center;">
    <div>
      {%- if section.settings.kicker != blank -%}<div class="tb-kicker">{{ section.settings.kicker }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="tb-section-title">{{ section.settings.heading }}</h2>{%- endif -%}
    </div>
  </div>
  <div class="tb-quotes">
    {%- for block in section.blocks -%}
      <figure class="tb-quote" {{ block.shopify_attributes }}>
        <div class="tb-quote__stars">{% for i in (1..block.settings.rating) %}&#9733;{% endfor %}</div>
        <blockquote class="tb-quote__text">{{ block.settings.quote }}</blockquote>
        <figcaption class="tb-quote__by">
          {%- if block.settings.avatar != blank -%}<img src="{{ block.settings.avatar | image_url: width: 80 }}" alt="{{ block.settings.name | escape }}">{%- else -%}<span class="tb-quote__ava">{{ block.settings.name | slice: 0 }}</span>{%- endif -%}
          <span><b>{{ block.settings.name }}</b><span>{{ block.settings.role }}</span></span>
        </figcaption>
      </figure>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "LOVED BY THOUSANDS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What customers say" }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Testimonial",
      "settings": [
        { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "label": "Stars", "default": 5 },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Best audio gear I’ve ever owned. The build quality is unreal and it sounds incredible." },
        { "type": "image_picker", "id": "avatar", "label": "Avatar" },
        { "type": "text", "id": "name", "label": "Name", "default": "Sara M." },
        { "type": "text", "id": "role", "label": "Role / location", "default": "Verified buyer" }
      ]
    }
  ],
  "max_blocks": 9,
  "presets": [ { "name": "Testimonials", "blocks": [ { "type": "quote" }, { "type": "quote" }, { "type": "quote" } ] } ]
}
{% endschema %}
