<section class="wrap tb-page" style="max-width:680px;">
  <nav class="tb-crumb"><a href="{{ routes.account_url }}">{{ 'customer.account.title' | t }}</a> / <b>{{ 'customer.addresses.title' | t | default: 'Addresses' }}</b></nav>
  <h1 class="tb-page__title">{{ 'customer.addresses.title' | t | default: 'Addresses' }}</h1>

  {%- form 'customer_address', customer.new_address -%}
    <div style="border:1px solid var(--line);border-radius:18px;padding:22px;margin-bottom:26px;">
      <h2 style="font-family:var(--display);font-size:18px;margin:0 0 16px;">{{ 'customer.addresses.add_new' | t | default: 'Add a new address' }}</h2>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <input class="tb-input" name="address[first_name]" placeholder="{{ 'customer.register.first_name' | t }}">
        <input class="tb-input" name="address[last_name]" placeholder="{{ 'customer.register.last_name' | t }}">
        <input class="tb-input" name="address[address1]" placeholder="Address" style="grid-column:1/-1;">
        <input class="tb-input" name="address[city]" placeholder="City">
        <input class="tb-input" name="address[zip]" placeholder="ZIP / Postal">
        <input class="tb-input" name="address[country]" placeholder="Country">
        <input class="tb-input" name="address[phone]" placeholder="Phone">
      </div>
      <button type="submit" class="tb-btn tb-btn--primary" style="margin-top:16px;">{{ 'customer.addresses.add' | t | default: 'Add address' }}</button>
    </div>
  {%- endform -%}

  {%- for address in customer.addresses -%}
    <div style="border:1px solid var(--line);border-radius:18px;padding:20px;margin-bottom:14px;">
      <div style="color:var(--muted);line-height:1.6;">{{ address | format_address }}</div>
      <form method="post" action="{{ address.url }}" style="margin-top:12px;display:inline;">
        <input type="hidden" name="_method" value="delete">
        <button type="submit" class="tb-remove">{{ 'customer.addresses.delete' | t | default: 'Delete' }}</button>
      </form>
    </div>
  {%- endfor -%}
</section>

{% schema %}
{ "name": "Addresses", "settings": [] }
{% endschema %}
