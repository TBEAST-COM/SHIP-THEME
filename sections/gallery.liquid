{%- comment -%} Lookbook / image gallery grid {%- endcomment -%}
<section class="{% if section.settings.full_width %}{% else %}wrap {% endif %}tb-reveal" style="padding-block:{% if section.settings.full_width %}0{% else %}48px{% endif %};">
  {%- if section.settings.heading != blank and section.settings.full_width == false -%}
    <div class="tb-section-head" style="justify-content:center;text-align:center;flex-direction:column;align-items:center;">
      <div>{%- if section.settings.kicker != blank -%}<div class="tb-kicker">{{ section.settings.kicker }}</div>{%- endif -%}<h2 class="tb-section-title">{{ section.settings.heading }}</h2></div>
    </div>
  {%- endif -%}
  <div class="tb-galgrid" style="--gal-cols:{{ section.settings.columns }};">
    {%- for block in section.blocks -%}
      {%- capture tag_open -%}{% if block.settings.link != blank %}<a href="{{ block.settings.link }}"{% else %}<div{% endif %} class="tb-galgrid__cell" style="grid-row:span {{ block.settings.row_span }};grid-column:span {{ block.settings.col_span }};" {{ block.shopify_attributes }}>{%- endcapture -%}
      {{ tag_open }}
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.caption | escape }}" loading="lazy">
        {%- else -%}
          <span class="tb-visual" style="width:100%;height:100%;"><span class="tb-visual__orb"></span></span>
        {%- endif -%}
        {%- if block.settings.caption != blank -%}<span class="tb-galgrid__cap">{{ block.settings.caption }}</span>{%- endif -%}
      {% if block.settings.link != blank %}</a>{% else %}</div>{% endif %}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Gallery",
  "settings": [
    { "type": "checkbox", "id": "full_width", "label": "Full width", "default": false },
    { "type": "range", "id": "columns", "min": 2, "max": 5, "step": 1, "label": "Columns", "default": 3 },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "LOOKBOOK" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "In the wild" }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "caption", "label": "Caption" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "select", "id": "row_span", "label": "Row span", "default": "1", "options": [ { "value": "1", "label": "1" }, { "value": "2", "label": "2" } ] },
        { "type": "select", "id": "col_span", "label": "Column span", "default": "1", "options": [ { "value": "1", "label": "1" }, { "value": "2", "label": "2" } ] }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [ { "name": "Gallery", "blocks": [ { "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" } ] } ]
}
{% endschema %}
