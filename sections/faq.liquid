{%- comment -%} FAQ accordion {%- endcomment -%}
<section class="wrap tb-reveal" style="padding-block:64px;">
  <div class="tb-faq">
    <div class="tb-faq__head">
      {%- if section.settings.kicker != blank -%}<div class="tb-kicker">{{ section.settings.kicker }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="tb-section-title">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}<p style="color:var(--muted);margin-top:14px;max-width:340px;">{{ section.settings.text }}</p>{%- endif -%}
    </div>
    <div class="tb-faq__list">
      {%- for block in section.blocks -%}
        <details class="tb-faq__item{% if forloop.first and section.settings.open_first %} is-open{% endif %}"{% if forloop.first and section.settings.open_first %} open{% endif %} {{ block.shopify_attributes }}>
          <summary class="tb-faq__q"><span>{{ block.settings.question }}</span><span class="tb-faq__icon" aria-hidden="true"></span></summary>
          <div class="tb-faq__a-wrap"><div class="tb-faq__a rte">{{ block.settings.answer }}</div></div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "SUPPORT" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked" },
    { "type": "text", "id": "text", "label": "Sub text", "default": "Everything you need to know before you buy." },
    { "type": "checkbox", "id": "open_first", "label": "Open first item", "default": true }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How long does shipping take?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Orders ship within 24 hours and arrive in 2–4 business days for most regions.</p>" }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [ { "name": "FAQ", "blocks": [ { "type": "qa" }, { "type": "qa" }, { "type": "qa" }, { "type": "qa" } ] } ]
}
{% endschema %}
