<section class="wrap tb-page">
  <h1 class="tb-page__title">{{ section.settings.heading | default: page.title }}</h1>
  {%- if section.settings.subheading != blank -%}
    <p style="color:var(--muted);max-width:560px;margin:-12px 0 30px;font-size:16px;line-height:1.6;">{{ section.settings.subheading }}</p>
  {%- endif -%}

  <div style="display:grid;grid-template-columns:1.3fr .9fr;gap:40px;align-items:start;">
    <!-- form -->
    <div style="border:1px solid var(--line);border-radius:20px;padding:28px;background:var(--card);">
      {%- form 'contact', id: 'tb-contact' -%}
        {%- if form.posted_successfully? -%}
          <div style="display:flex;align-items:center;gap:12px;border:1px solid oklch(0.55 0.1 140);background:oklch(0.74 0.10 140 / 0.12);color:oklch(0.82 0.12 140);border-radius:12px;padding:14px 16px;margin-bottom:20px;">
            <span>&#10003;</span><span>{{ 'contact.form.success' | t }}</span>
          </div>
        {%- elsif form.errors -%}
          <div style="color:var(--sale);border:1px solid oklch(0.55 0.1 55);border-radius:12px;padding:14px 16px;margin-bottom:20px;">{{ form.errors | default_errors }}</div>
        {%- endif -%}

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div>
            <label class="tb-card__sub" for="cf-name">{{ 'contact.form.name' | t }}</label>
            <input class="tb-input" style="width:100%;margin-top:6px;" id="cf-name" type="text" name="contact[name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" autocomplete="name">
          </div>
          <div>
            <label class="tb-card__sub" for="cf-phone">{{ 'contact.form.phone' | t }}</label>
            <input class="tb-input" style="width:100%;margin-top:6px;" id="cf-phone" type="tel" name="contact[phone]" value="{{ form.phone }}" autocomplete="tel">
          </div>
        </div>
        <div style="margin-top:14px;">
          <label class="tb-card__sub" for="cf-email">{{ 'contact.form.email' | t }}</label>
          <input class="tb-input" style="width:100%;margin-top:6px;" id="cf-email" type="email" name="contact[email]" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" autocomplete="email" required>
        </div>
        <div style="margin-top:14px;">
          <label class="tb-card__sub" for="cf-body">{{ 'contact.form.message' | t }}</label>
          <textarea class="tb-input" style="width:100%;margin-top:6px;height:140px;padding-top:12px;resize:vertical;" id="cf-body" name="contact[body]" required>{{ form.body }}</textarea>
        </div>
        <button type="submit" class="tb-btn tb-btn--primary" style="margin-top:20px;">{{ 'contact.form.submit' | t }}</button>
      {%- endform -%}
    </div>

    <!-- info column -->
    <div style="display:flex;flex-direction:column;gap:14px;">
      {%- for block in section.blocks -%}
        <div style="border:1px solid var(--line);border-radius:16px;padding:20px;background:var(--surface);" {{ block.shopify_attributes }}>
          <div class="tb-card__sub" style="margin-bottom:6px;">{{ block.settings.label }}</div>
          <div style="font-size:16px;color:var(--text);line-height:1.5;">
            {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}" style="color:var(--accent-2);">{{ block.settings.value }}</a>
            {%- else -%}{{ block.settings.value }}{%- endif -%}
          </div>
        </div>
      {%- endfor -%}
      {%- if page.content != blank -%}
        <div class="rte" style="border:1px solid var(--line);border-radius:16px;padding:20px;background:var(--surface);">{{ page.content }}</div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact form",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Contact" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Questions, support, partnerships — send us a message and we’ll reply within 24 hours." }
  ],
  "blocks": [
    {
      "type": "info",
      "name": "Info item",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Email" },
        { "type": "text", "id": "value", "label": "Value", "default": "support@tbeast.com" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact form",
      "blocks": [
        { "type": "info", "settings": { "label": "Email", "value": "support@tbeast.com" } },
        { "type": "info", "settings": { "label": "Hours", "value": "Sun–Thu · 9am – 6pm" } }
      ]
    }
  ]
}
{% endschema %}
