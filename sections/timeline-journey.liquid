{%- comment -%} Timeline Journey — vertical scroll-fill timeline, TBEAST identity {%- endcomment -%}
{%- liquid
  assign title = section.settings.title
  if section.settings.highlight_word != blank
    assign replacement = '<span style="color:var(--accent-2);">' | append: section.settings.highlight_word | append: '</span>'
    assign title = title | replace: section.settings.highlight_word, replacement
  endif
-%}

{%- style -%}
  .tb-tlj-{{ section.id }}{ padding-block:{{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; position:relative; z-index:1; }
  .tb-tlj-{{ section.id }} .tb-tlj-wrap{ max-width:880px; margin:0 auto; padding-inline:28px; }
  .tb-tlj-{{ section.id }} .tb-tlj-head{ text-align:center; margin-bottom:64px; }
  .tb-tlj-{{ section.id }} .tb-tlj-h{ font-family:var(--display); font-weight:700; font-size:clamp(32px,5vw,52px); line-height:1.05; letter-spacing:-0.01em; margin:10px 0 16px; color:var(--text); }
  .tb-tlj-{{ section.id }} .tb-tlj-sub{ font-size:16px; color:var(--muted); max-width:600px; margin:0 auto; line-height:1.6; }
  .tb-tlj-{{ section.id }} .tb-tlj-line{ position:relative; padding-inline-start:54px; }
  .tb-tlj-{{ section.id }} .tb-tlj-bg, .tb-tlj-{{ section.id }} .tb-tlj-fill{ position:absolute; top:8px; inset-inline-start:15px; width:2px; }
  .tb-tlj-{{ section.id }} .tb-tlj-bg{ bottom:40px; background:var(--line); }
  .tb-tlj-{{ section.id }} .tb-tlj-fill{ height:0%; background:linear-gradient(180deg,var(--accent),var(--accent-2)); box-shadow:0 0 12px var(--accent); transition:height .5s cubic-bezier(.1,.7,.1,1); }
  .tb-tlj-{{ section.id }} .tb-tlj-item{ position:relative; padding-bottom:48px; opacity:0; transform:translateY(28px); transition:opacity .7s ease, transform .7s cubic-bezier(.2,.7,.2,1); }
  .tb-tlj-{{ section.id }} .tb-tlj-item.is-visible{ opacity:1; transform:none; }
  .tb-tlj-{{ section.id }} .tb-tlj-item:last-child{ padding-bottom:0; }
  .tb-tlj-{{ section.id }} .tb-tlj-node{ position:absolute; top:0; inset-inline-start:-54px; width:32px; height:32px; border-radius:50%; background:var(--bg); border:2px solid var(--line); display:grid; place-items:center; z-index:3; transition:.45s cubic-bezier(.2,.7,.2,1); }
  .tb-tlj-{{ section.id }} .tb-tlj-node::after{ content:""; width:9px; height:9px; border-radius:50%; background:var(--accent); transform:scale(0); transition:transform .45s cubic-bezier(.2,.7,.2,1); }
  .tb-tlj-{{ section.id }} .tb-tlj-item.is-visible .tb-tlj-node{ border-color:var(--accent); box-shadow:0 0 0 5px var(--bg), 0 0 18px oklch(0.72 0.14 55 / 0.5); }
  .tb-tlj-{{ section.id }} .tb-tlj-item.is-visible .tb-tlj-node::after{ transform:scale(1); }
  .tb-tlj-{{ section.id }} .tb-tlj-card{ background:var(--card); border:1px solid var(--line); border-radius:var(--radius); padding:26px 28px; position:relative; top:-14px; transition:.3s ease; }
  .tb-tlj-{{ section.id }} .tb-tlj-item.is-visible:hover .tb-tlj-card{ border-color:var(--accent); transform:translateY(-3px); box-shadow:0 18px 44px oklch(0 0 0 / 0.4); }
  .tb-tlj-{{ section.id }} .tb-tlj-pill{ display:inline-block; font-family:var(--mono); font-size:11px; font-weight:600; letter-spacing:.08em; text-transform:uppercase; color:var(--bg); background:linear-gradient(135deg,var(--sale),var(--accent)); padding:5px 13px; border-radius:30px; margin-bottom:14px; }
  .tb-tlj-{{ section.id }} .tb-tlj-it{ font-family:var(--display); font-weight:600; font-size:21px; line-height:1.3; margin-bottom:10px; color:var(--text); }
  .tb-tlj-{{ section.id }} .tb-tlj-desc{ font-size:14.5px; line-height:1.7; color:var(--muted); }
  @media (max-width:768px){
    .tb-tlj-{{ section.id }} .tb-tlj-line{ padding-inline-start:42px; }
    .tb-tlj-{{ section.id }} .tb-tlj-bg, .tb-tlj-{{ section.id }} .tb-tlj-fill{ inset-inline-start:10px; }
    .tb-tlj-{{ section.id }} .tb-tlj-node{ inset-inline-start:-42px; width:22px; height:22px; }
    .tb-tlj-{{ section.id }} .tb-tlj-card{ padding:22px 20px; }
  }
{%- endstyle -%}

<section class="tb-tlj-{{ section.id }}" {{ section.shopify_attributes }}>
  <div class="tb-tlj-wrap">
    <div class="tb-tlj-head">
      {%- if section.settings.kicker != blank -%}<div class="tb-kicker">{{ section.settings.kicker }}</div>{%- endif -%}
      {%- if title != blank -%}<h2 class="tb-tlj-h">{{ title }}</h2>{%- endif -%}
      {%- if section.settings.subtitle != blank -%}<div class="tb-tlj-sub">{{ section.settings.subtitle }}</div>{%- endif -%}
    </div>
    <div class="tb-tlj-line" id="tlj-wrap-{{ section.id }}">
      <div class="tb-tlj-bg"></div>
      <div class="tb-tlj-fill" id="tlj-fill-{{ section.id }}"></div>
      {%- for block in section.blocks -%}
        <div class="tb-tlj-item js-tlj-item" {{ block.shopify_attributes }}>
          <div class="tb-tlj-node"></div>
          <div class="tb-tlj-card">
            {%- if block.settings.pill_text != blank -%}<div class="tb-tlj-pill">{{ block.settings.pill_text }}</div>{%- endif -%}
            {%- if block.settings.heading != blank -%}<h3 class="tb-tlj-it">{{ block.settings.heading }}</h3>{%- endif -%}
            {%- if block.settings.description != blank -%}<div class="tb-tlj-desc">{{ block.settings.description }}</div>{%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
(function(){
  var wrap=document.getElementById('tlj-wrap-{{ section.id }}');
  var fill=document.getElementById('tlj-fill-{{ section.id }}');
  if(!wrap||!fill) return;
  var items=wrap.querySelectorAll('.js-tlj-item');
  if('IntersectionObserver' in window){
    var io=new IntersectionObserver(function(es){ es.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('is-visible'); } }); },{threshold:0.12, rootMargin:'0px 0px -10% 0px'});
    items.forEach(function(it){ io.observe(it); });
  } else { items.forEach(function(it){ it.classList.add('is-visible'); }); }
  function upd(){
    var r=wrap.getBoundingClientRect(), vh=window.innerHeight, trig=vh*0.7;
    if(r.top<trig){ var p=Math.min(Math.max(((trig-r.top)/r.height)*100,0),100); fill.style.height=p+'%'; }
    else fill.style.height='0%';
  }
  window.addEventListener('scroll',upd,{passive:true}); upd();
})();
</script>

{% schema %}
{
  "name": "Timeline Journey",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "THE PROCESS" },
    { "type": "text", "id": "title", "label": "Heading", "default": "The TBEAST adaptation journey" },
    { "type": "text", "id": "highlight_word", "label": "Word to highlight", "default": "TBEAST" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Exactly what to expect as you move from unboxing to peak performance." },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Top padding", "default": 72 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Bottom padding", "default": 72 }
  ],
  "blocks": [
    { "type": "phase", "name": "Journey phase", "settings": [
      { "type": "text", "id": "pill_text", "label": "Timeframe tag", "default": "Step 1" },
      { "type": "text", "id": "heading", "label": "Heading", "default": "Unbox & pair" },
      { "type": "textarea", "id": "description", "label": "Description", "default": "Power on, pair in seconds, and the companion app guides your first setup." }
    ]}
  ],
  "presets": [
    { "name": "Timeline Journey", "blocks": [
      { "type": "phase", "settings": { "pill_text": "Step 1", "heading": "Unbox & pair", "description": "Power on, pair in seconds over Bluetooth 5.4, and the companion app walks you through a guided first setup." } },
      { "type": "phase", "settings": { "pill_text": "Step 2", "heading": "Tune your sound", "description": "Pick a preset or build your own EQ curve. Adaptive ANC calibrates automatically to your ears and surroundings." } },
      { "type": "phase", "settings": { "pill_text": "Step 3", "heading": "Live with it", "description": "42-hour battery means days between charges. Multipoint keeps you connected to laptop and phone at once." } },
      { "type": "phase", "settings": { "pill_text": "Step 4", "heading": "Peak performance", "description": "Firmware keeps improving over time. Your gear gets better the longer you own it — this is the new baseline." } }
    ]}
  ]
}
{% endschema %}
