{%- assign fp = section.settings.featured_product -%}
<section class="wrap tb-hero">
  <div class="tb-hero__copy">
    {%- if section.settings.kicker != blank -%}
      <div class="tb-pill"><span class="tb-dot"></span>{{ section.settings.kicker }}</div>
    {%- endif -%}
    <h1>{{ section.settings.heading }}</h1>
    {%- if section.settings.subheading != blank -%}<p class="tb-hero__desc">{{ section.settings.subheading }}</p>{%- endif -%}
    <div class="tb-hero__cta">
      {%- if section.settings.button_text != blank -%}
        <a class="tb-btn tb-btn--primary" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">{{ section.settings.button_text }}</a>
      {%- endif -%}
      {%- if section.settings.button_2_text != blank -%}
        <a class="tb-btn" href="{{ section.settings.button_2_link | default: fp.url }}">{{ section.settings.button_2_text }}</a>
      {%- endif -%}
    </div>
    {%- if section.blocks.size > 0 -%}
      <div class="tb-stats">
        {%- for block in section.blocks -%}
          <div {{ block.shopify_attributes }}>
            <div class="tb-stats__num">{{ block.settings.number }}</div>
            <div class="tb-stats__label">{{ block.settings.label }}</div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <div class="tb-hero__visual">
    <div class="tb-hero__glow"></div>
    <div class="tb-ring tb-ring--1"></div>
    <div class="tb-ring tb-ring--2"></div>
    <a class="tb-hero__card" href="{{ fp.url | default: routes.all_products_collection_url }}">
      <div class="tb-scan"></div>
      {%- if fp != blank and fp.featured_image -%}
        <img src="{{ fp.featured_image | image_url: width: 600 }}" alt="{{ fp.title | escape }}" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
        <div class="tb-hero__card-shade"></div>
      {%- else -%}
        <div class="tb-lens"></div>
      {%- endif -%}
      <span class="tb-hero__tag tb-hero__tag--a">{{ fp.title | default: 'TBEAST' | upcase | truncate: 12, '' }}</span>
      <span class="tb-hero__tag tb-hero__tag--b">{% if fp != blank %}{{ fp.price | money_without_trailing_zeros }}{% else %}TBEAST{% endif %}</span>
    </a>
    {%- if section.settings.chip_1 != blank -%}<span class="tb-chip-float" style="top:34px;inset-inline-end:6px;">{{ section.settings.chip_1 }}</span>{%- endif -%}
    {%- if section.settings.chip_2 != blank -%}<span class="tb-chip-float" style="bottom:50px;inset-inline-start:0;">{{ section.settings.chip_2 }}</span>{%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "NEXT-GEN HARDWARE" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Sound engineered\nbeyond limits" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Precision-built audio and tech with warm materials and performance that never compromises." },
    { "type": "text", "id": "button_text", "label": "Primary button", "default": "Shop now" },
    { "type": "url", "id": "button_link", "label": "Primary link" },
    { "type": "text", "id": "button_2_text", "label": "Secondary button", "default": "Explore" },
    { "type": "url", "id": "button_2_link", "label": "Secondary link" },
    { "type": "product", "id": "featured_product", "label": "Featured product (floating card)" },
    { "type": "text", "id": "chip_1", "label": "Floating chip 1", "default": "ANC · 42h" },
    { "type": "text", "id": "chip_2", "label": "Floating chip 2", "default": "Hi-Res Audio" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "120K+" },
        { "type": "text", "id": "label", "label": "Label", "default": "Happy customers" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "stat", "settings": { "number": "120K+", "label": "Happy customers" } },
        { "type": "stat", "settings": { "number": "4.8★", "label": "Average rating" } },
        { "type": "stat", "settings": { "number": "42h", "label": "Battery life" } }
      ]
    }
  ]
}
{% endschema %}
