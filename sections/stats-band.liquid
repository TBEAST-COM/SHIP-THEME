{%- comment -%} Stats / numbers band {%- endcomment -%}
<section class="wrap tb-reveal" style="padding-block:48px;">
  <div class="tb-stats" style="--stats-bg:{{ section.settings.bg_color }};">
    <div class="tb-stats__glow"></div>
    {%- if section.settings.heading != blank -%}
      <div class="tb-stats__head">
        {%- if section.settings.kicker != blank -%}<div class="tb-kicker" style="color:var(--accent-2);">{{ section.settings.kicker }}</div>{%- endif -%}
        <h2 class="tb-section-title" style="font-size:clamp(24px,3.2vw,34px);">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}
    <div class="tb-stats__grid">
      {%- for block in section.blocks -%}
        <div class="tb-stats__item" {{ block.shopify_attributes }}>
          <div class="tb-stats__num">{{ block.settings.number }}</div>
          <div class="tb-stats__label">{{ block.settings.label }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Stats band",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#221b14" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "BY THE NUMBERS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Trusted worldwide" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "120K+" },
        { "type": "text", "id": "label", "label": "Label", "default": "Happy customers" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [ { "name": "Stats band", "blocks": [ { "type": "stat" }, { "type": "stat" }, { "type": "stat" }, { "type": "stat" } ] } ]
}
{% endschema %}
