{%- comment -%} Image + text split section {%- endcomment -%}
<section class="wrap tb-reveal" style="padding-block:64px;">
  <div class="tb-split{% if section.settings.reverse %} tb-split--rev{% endif %}">
    <div class="tb-split__media">
      {%- if section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 1000 }}" alt="{{ section.settings.image.alt | escape }}" loading="lazy">
      {%- else -%}
        <span class="tb-visual" style="width:100%;height:100%;border-radius:var(--radius);"><span class="tb-visual__orb"></span></span>
      {%- endif -%}
      {%- if section.settings.badge != blank -%}<span class="tb-split__badge">{{ section.settings.badge }}</span>{%- endif -%}
    </div>
    <div class="tb-split__body">
      {%- if section.settings.kicker != blank -%}<div class="tb-kicker">{{ section.settings.kicker }}</div>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="tb-section-title" style="font-size:clamp(28px,4vw,42px);">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}<div class="rte" style="margin-top:16px;color:var(--muted);max-width:480px;">{{ section.settings.text }}</div>{%- endif -%}
      {%- if section.blocks.size > 0 -%}
        <ul class="tb-split__list">
          {%- for block in section.blocks -%}
            <li {{ block.shopify_attributes }}><span class="tb-split__tick">&#10003;</span>{{ block.settings.text }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
      {%- if section.settings.button_text != blank -%}
        <a class="tb-btn tb-btn--primary" style="margin-top:28px;" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">{{ section.settings.button_text }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "badge", "label": "Image badge" },
    { "type": "checkbox", "id": "reverse", "label": "Reverse layout", "default": false },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "WHY TBEAST" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built to outlast the hype" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Every device is engineered with premium materials and obsessive attention to detail — so it performs as good as it looks, for years.</p>" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Shop the range" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "blocks": [
    { "type": "feature", "name": "Checklist item", "settings": [ { "type": "text", "id": "text", "label": "Text", "default": "Free 2-year warranty" } ] }
  ],
  "max_blocks": 6,
  "presets": [ { "name": "Image with text", "blocks": [ { "type": "feature" }, { "type": "feature" }, { "type": "feature" } ] } ]
}
{% endschema %}
