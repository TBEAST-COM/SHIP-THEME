<header class="tb-header">
  <div class="wrap tb-header__inner">
    <a href="{{ routes.root_url }}" class="tb-logo">
      {%- if settings.logo != blank -%}
        <span class="tb-logo__mark" style="width:auto;background:none;box-shadow:none;border-radius:0;">
          <img src="{{ settings.logo | image_url: width: 220 }}" alt="{{ shop.name }}" style="width:{{ settings.logo_width }}px;height:auto;">
        </span>
      {%- else -%}
        <span class="tb-logo__mark">T</span>
        <span class="tb-logo__name">{{ shop.name | default: 'TBEAST' }}</span>
      {%- endif -%}
    </a>

    {%- if section.settings.menu != blank -%}
      <nav class="tb-nav" aria-label="Primary">
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
        {%- endfor -%}
      </nav>
    {%- endif -%}

    <div class="tb-header__actions">
      <button type="button" class="tb-icon-btn" data-search-open aria-label="{{ 'general.search.title' | t }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      </button>

      {%- if settings.show_language_toggle and localization.available_languages.size > 1 -%}
        {%- form 'localization', id: 'tb-lang-form', class: 'tb-lang-form' -%}
          <select name="locale_code" class="tb-lang" onchange="this.form.submit()" aria-label="Language">
            {%- for language in localization.available_languages -%}
              <option value="{{ language.iso_code }}"{% if language.iso_code == localization.language.iso_code %} selected{% endif %}>{{ language.endonym_name }}</option>
            {%- endfor -%}
          </select>
        {%- endform -%}
      {%- endif -%}

      <button type="button" class="tb-icon-btn" data-cart-open aria-label="{{ 'general.accessibility.cart' | t }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v13a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="tb-badge-count" data-cart-count{% if cart.item_count == 0 %} style="display:none"{% endif %}>{{ cart.item_count }}</span>
      </button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" }
  ]
}
{% endschema %}
