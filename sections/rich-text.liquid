{%- comment -%} Rich text / about block {%- endcomment -%}
<section class="wrap tb-reveal" style="padding-block:64px;text-align:{{ section.settings.align }};">
  <div style="max-width:{{ section.settings.width }}px;margin-inline:{% if section.settings.align == 'center' %}auto{% else %}0{% endif %};">
    {%- if section.settings.kicker != blank -%}<div class="tb-kicker">{{ section.settings.kicker }}</div>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="tb-section-title" style="font-size:clamp(28px,4.4vw,46px);">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.text != blank -%}<div class="rte" style="margin-top:18px;font-size:18px;line-height:1.7;color:var(--muted);">{{ section.settings.text }}</div>{%- endif -%}
    {%- if section.settings.button_text != blank -%}
      <a class="tb-btn tb-btn--ghost" style="margin-top:28px;" href="{{ section.settings.button_link }}">{{ section.settings.button_text }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Rich text",
  "settings": [
    { "type": "select", "id": "align", "label": "Alignment", "options": [ {"value":"start","label":"Left"}, {"value":"center","label":"Center"} ], "default": "center" },
    { "type": "range", "id": "width", "min": 480, "max": 900, "step": 20, "unit": "px", "label": "Max width", "default": 720 },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "OUR STORY" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Technology with a warmer soul" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>We started TBEAST to prove that high-performance tech doesn’t have to feel cold. Warm materials, honest engineering, and design that lasts.</p>" },
    { "type": "text", "id": "button_text", "label": "Button text" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [ { "name": "Rich text" } ]
}
{% endschema %}
