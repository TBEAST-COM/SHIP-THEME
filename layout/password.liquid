<!doctype html>
<html lang="{{ request.locale.iso_code }}" dir="{% if request.locale.iso_code == 'ar' or settings.force_rtl %}rtl{% else %}ltr{% endif %}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }}</title>
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=IBM+Plex+Sans+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet">
  {{ 'base.css' | asset_url | stylesheet_tag }}
</head>
<body>
  <main id="MainContent" style="min-height:100vh;display:grid;place-items:center;text-align:center;padding:40px;">
    <div>
      <div class="tb-logo" style="justify-content:center;margin-bottom:24px;">
        <span class="tb-logo__mark">T</span>
        <span class="tb-logo__name">{{ shop.name }}</span>
      </div>
      <h1 style="font-family:var(--display);font-weight:700;font-size:clamp(30px,5vw,52px);letter-spacing:-.01em;margin:0 0 12px;">{{ 'general.password.title' | t }}</h1>
      <p style="color:var(--muted);max-width:420px;margin:0 auto 26px;">{{ shop.password_message | default: 'general.password.text' | t }}</p>
      <div style="max-width:380px;margin:0 auto;">
        {%- form 'storefront_password' -%}
          <div style="display:flex;gap:10px;">
            <input class="tb-input" type="password" name="password" placeholder="{{ 'general.password.placeholder' | t }}" autocomplete="off">
            <button class="tb-btn tb-btn--primary" type="submit">{{ 'general.password.submit' | t }}</button>
          </div>
          {%- if form.errors -%}<p style="color:var(--sale);margin-top:10px;">{{ form.errors | default_errors }}</p>{%- endif -%}
        {%- endform -%}
      </div>
      <p class="mono" style="color:var(--faint);font-size:12px;margin-top:40px;">{{ powered_by_link }}</p>
    </div>
  </main>
</body>
</html>
